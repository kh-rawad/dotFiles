# ── User & Path Configuration ───────────────────────────────────────────────
# UID/GID of the user that will own the media files (run: id -u  /  id -g)
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Root path on the host where all service config/data lives
CONFIG_ROOT=/opt/mediaserver/config

# Root path on the host where media files live
MEDIA_ROOT=/mnt/media

# ── Network / Ports ──────────────────────────────────────────────────────────
# Jellyfin
JELLYFIN_HTTP_PORT=8096
JELLYFIN_HTTPS_PORT=8920

# Sonarr
SONARR_PORT=8989

# Radarr
RADARR_PORT=7878

# Prowlarr
PROWLARR_PORT=9696

# qBittorrent WebUI
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_TCP_PORT=6881
QBITTORRENT_UDP_PORT=6881

# Nginx Proxy Manager
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81
